# Google Gemini API key — get one at https://aistudio.google.com/apikey
# Set this in the Vercel dashboard (Project → Settings → Environment Variables).
# For local `vercel dev`, copy this file to .env.local and put your key here.
# The key lives only on the server side — it never reaches the browser bundle.
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional model overrides (default: gemini-2.5-flash for both).
# CHAT_MODEL=gemini-2.0-flash
# RESUME_MODEL=gemini-2.5-pro
