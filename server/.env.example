# ── Required ───────────────────────────────────────────────────────────────
# Your Google Gemini API key. Get one at https://aistudio.google.com/apikey
# This lives ONLY on the server and is never shipped to the browser.
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional ───────────────────────────────────────────────────────────────
# Port the API listens on (the Vite dev proxy expects 8787 by default).
PORT=8787

# Models. Defaults to Gemini 2.5 Flash — fast and cheap, plenty for portfolio
# Q&A and the role-fit analysis. Swap to gemini-2.5-pro for stronger reasoning
# (e.g. on the resume route) or gemini-2.0-flash for the lowest cost.
CHAT_MODEL=gemini-2.5-flash
RESUME_MODEL=gemini-2.5-flash

# Comma-separated list of browser origins allowed to call the API.
# localhost:5173 (Vite dev) and the GitHub Pages site are allowed by default;
# add your deployed frontend origin here in production.
ALLOWED_ORIGINS=https://rajrishi-06.github.io
