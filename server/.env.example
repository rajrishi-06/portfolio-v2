# ── Required ───────────────────────────────────────────────────────────────
# Your Anthropic API key. Get one at https://console.anthropic.com/
# This lives ONLY on the server and is never shipped to the browser.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional ───────────────────────────────────────────────────────────────
# Port the API listens on (the Vite dev proxy expects 8787 by default).
PORT=8787

# Models. Defaults to Claude Opus 4.8 for the best answers. For a public-facing
# widget you'll almost certainly want to switch the chat to a cheaper/faster
# model — claude-haiku-4-5 ($1/$5 per MTok) is plenty for portfolio Q&A.
# Resume analysis benefits from a stronger model; sonnet/opus recommended there.
CHAT_MODEL=claude-opus-4-8
RESUME_MODEL=claude-opus-4-8

# Comma-separated list of browser origins allowed to call the API.
# localhost:5173 (Vite dev) and the GitHub Pages site are allowed by default;
# add your deployed frontend origin here in production.
ALLOWED_ORIGINS=https://rajrishi-06.github.io
